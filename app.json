{
  "expo": {
    "name": "Card Valuer",
    "slug": "card-valuer",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0a0a0a",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "supportsTablet": true,
      "deploymentTarget": "16.0",
      "infoPlist": {
        "NSCameraUsageDescription": "Card Valuer needs camera access to scan Pokemon TCG cards.",
        "NSPhotoLibraryUsageDescription": "Card Valuer needs photo library access to save and share card scan exports.",
        "NSPhotoLibraryAddUsageDescription": "Card Valuer needs permission to save exported files to your photo library."
      },
      "bundleIdentifier": "com.tomlafferty.cardvaluer"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0a"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ]
    },
    "plugins": [
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Card Valuer needs camera access to scan Pokemon TCG cards.",
          "enableCodeScanner": true
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Card Valuer to access your photos.",
          "savePhotosPermission": "Allow Card Valuer to save photos.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.0"
          }
        }
      ]
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
